{
  "name": "wargame-adjudicator",
  "version": "0.1.0",
  "description": "Agent-driven wargaming adjudicator with persisted async human-in-the-loop escalation.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wargame": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
