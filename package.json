    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.73.0",
    "seedrandom": "^3.0.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/seedrandom": "^3.0.8",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
